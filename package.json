{
  "name": "yolo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "npm run generate:toolbox-registry && npm run generate:release-id",
    "predev": "npm run generate:toolbox-registry && npm run generate:release-id",
    "pretest": "npm run generate:toolbox-registry && npm run generate:release-id",
    "pretypecheck": "npm run generate:toolbox-registry && npm run generate:release-id",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "analyze": "next experimental-analyze --output",
    "format:check": "prettier --check .",
    "generate:release-id": "tsx scripts/generate-release-id.ts",
    "generate:toolbox-registry": "tsx scripts/generate-toolbox-registry.ts"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "feed": "^6.0.0",
    "js-yaml": "^4.3.0",
    "marked": "^18.0.3",
    "marked-alert": "^2.1.2",
    "mermaid": "^11.15.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "qrcode-generator": "^2.0.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "^2.17.4",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@google-cloud/bigquery": "^8.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/gtag.js": "^0.0.20",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "fast-glob": "^3.3.3",
    "jsdom": "29.1.1",
    "ml-kmeans": "^7.0.0",
    "playwright": "^1.59.1",
    "prettier": "3.9.5",
    "sharp": "^0.35.3",
    "tsx": "^4.22.3",
    "typescript": "7.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "eslint-plugin-react-hooks": "7.0.1"
  }
}
