{
  "name": "yolo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "npm run generate:toolbox-registry && npm run generate:static-assets",
    "predev": "npm run generate:toolbox-registry && npm run generate:static-assets",
    "pretest": "npm run generate:toolbox-registry && npm run generate:static-assets",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "analyze": "next experimental-analyze --output",
    "format:check": "prettier --check .",
    "generate:static-assets": "tsx scripts/build-search-index.ts",
    "generate:toolbox-registry": "tsx scripts/generate-toolbox-registry.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "diff": "^9.0.0",
    "feed": "^5.2.1",
    "fuse.js": "^7.3.0",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.3",
    "marked-alert": "^2.1.2",
    "mermaid": "^11.14.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "qrcode-generator": "^2.0.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@google-cloud/bigquery": "^8.3.0",
    "@huggingface/transformers": "^4.2.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/gtag.js": "^0.0.20",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "10.1.8",
    "fast-glob": "^3.3.3",
    "jsdom": "29.1.1",
    "ml-kmeans": "^7.0.0",
    "playwright": "^1.59.1",
    "prettier": "3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  }
}
